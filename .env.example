# ── eBay API ─────────────────────────────────────────────────────────────────
# Sign up at https://developer.ebay.com → My Account → Application Keys
EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_APP_ID=your_ebay_app_id_here        # Same as Client ID — used for Finding API
EBAY_ENVIRONMENT=production              # "production" or "sandbox"

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+16026339330          # Your purchased Twilio number
TWILIO_TO_NUMBER=+17088376553            # Connor's personal number

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string_in_production
DASHBOARD_PASSWORD=crazycardz2024       # Change this immediately after setup

# ── Scanner ───────────────────────────────────────────────────────────────────
MOCK_SCANNER=true                        # Set to false once eBay credentials are live
SCAN_INTERVAL_SECONDS=45                 # How often to scan eBay (min ~30 to stay under rate limits)
COMP_REFRESH_HOURS=8                     # How often to refresh FMV comps (3x/day = 8h)

# ── Spend Controls ────────────────────────────────────────────────────────────
MAX_SPEND_PER_CARD=2500
MAX_SPEND_PER_DAY=5000
MIN_CARD_PRICE=100
